{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️  File edited. Run tests if applicable.'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(DROP TABLE*)",
      "Bash(DELETE FROM*)"
    ]
  }
}